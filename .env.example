# Application
APP_NAME=AetherSentinel
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_APP_NAME=AetherSentinel
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_DB=aethersentinel
POSTGRES_USER=aethersentinel_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aethersentinel_user:change_me@postgres:5432/aethersentinel

# Auth (development placeholder)
DEV_AUTH_ENABLED=true
DEV_AUTH_DEFAULT_ROLE=admin
DEV_AUTH_DEFAULT_USER=local_admin

# AI / Agent layer
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
AGENT_MAX_TOOL_CALLS=5

# Security / app behavior
ALLOW_WRITE_ACTIONS=false
REQUIRE_APPROVAL_FOR_WRITES=true
AUDIT_LOG_ENABLED=true

# MCP
MCP_SERVER_ENABLED=false
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9000
